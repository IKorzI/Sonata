{
  "name": "sonata",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "vite:dev": "vite",
    "electron:dev": "nodemon",
    "app:dev": "concurrently -k \"npm run vite:dev\" \"npm run electron:dev\"",
    "C#:build": "src\\scripts\\C#\\CustomSaveDialog\\build.bat",
    "py:build": "src\\scripts\\python\\build.bat",
    "vite:build": "vite build",
    "electron:build": "electron-builder --config.forceCodeSigning=false --config.generateUpdatesFilesForAllChannels=false",
    "electron:publish": "electron-builder --config.forceCodeSigning=false --config.generateUpdatesFilesForAllChannels=false --publish always",
    "app:build": "npm run C#:build && npm run py:build && npm run vite:build && npm run electron:build",
    "app:publish": "npm run C#:build && npm run py:build && npm run vite:build && npm run electron:publish",
    "app:prebuild": "npm run C#:build && npm run py:build && npm run vite:build",
    "py:test": "src\\scripts\\python\\test.bat",
    "app:test": "node run-tests.js",
    "app:testDebug": "npx playwright test --debug "
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "fs": "^0.0.1-security",
    "shevchenko": "^3.2.2",
    "svelte": "^4.2.7",
    "web-streams-polyfill": "^4.2.0",
    "xlsx": "^0.18.5",
    "xlsx-populate": "^1.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "adm-zip": "^0.5.17",
    "concurrently": "^9.1.2",
    "electron": "^22.0.0",
    "electron-builder": "^23.6.0",
    "nodemon": "^3.1.10",
    "vite": "^5.4.21",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.sonata",
    "productName": "Sonata",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.cjs",
      "main.js",
      "preload.cjs",
      "src/scripts/other/**/*.{exe,dll}",
      "src/scripts/**/*.js",
      "public/**/*",
      "locales/**/*",
      {
        "from": "dist-vite",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      },
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/scripts/python",
        "to": "python-backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": false,
    "win": {
      "icon": "public/icon.ico",
      "target": "nsis"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IKorzI/Sonata"
  }
}
